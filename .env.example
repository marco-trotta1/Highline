# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored — never commit real credentials here.

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<your-publishable-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-jwt>

# NASS Quick Stats (USDA) — https://quickstats.nass.usda.gov/api
# Used by Supabase Edge Functions for cold-storage and slaughter ingest
NASS_API_KEY=<your-nass-api-key>

# Playwright (for futures scraper) — set to "false" to watch the browser locally
PLAYWRIGHT_HEADLESS=true
